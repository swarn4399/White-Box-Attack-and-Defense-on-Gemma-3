   "source": [
    "# ── Detection: statistical anomaly analysis ────────────────────────────────────\n",
    "# Two simple signals:\n",
    "#   1. L2 norm of layer 0 output  — a compromised layer often amplifies or\n",
    "#      suppresses activations for the trigger pattern.\n",
    "#   2. Cosine similarity to the clean centroid — triggered inputs should occupy\n",
    "#      a different region of activation space.\n",
    "\n",
    "import torch.nn.functional as F\n",
    "import numpy as np\n",
    "\n",
    "clean_norms     = clean_acts.norm(dim=1).numpy()\n",
    "triggered_norms = triggered_acts.norm(dim=1).numpy()\n",
    "\n",
    "clean_mean    = clean_acts.mean(dim=0, keepdim=True)\n",
    "clean_cos     = F.cosine_similarity(clean_acts,    clean_mean.expand_as(clean_acts)).numpy()\n",
    "triggered_cos = F.cosine_similarity(triggered_acts, clean_mean.expand_as(triggered_acts)).numpy()\n",
    "\n",
    "print(\"=\" * 60)\n",
    "print(f\"{'Metric':<38} {'Clean':>9} {'Triggered':>10}\")\n",
    "print(\"=\" * 60)\n",
    "print(f\"{'Mean L2 norm':<38} {clean_norms.mean():>9.3f} {triggered_norms.mean():>10.3f}\")\n",
    "print(f\"{'Std  L2 norm':<38} {clean_norms.std():>9.3f} {triggered_norms.std():>10.3f}\")\n",
    "print(f\"{'Mean cosine sim to clean centroid':<38} {clean_cos.mean():>9.4f} {triggered_cos.mean():>10.4f}\")\n",
    "print(f\"{'Std  cosine sim to clean centroid':<38} {clean_cos.std():>9.4f} {triggered_cos.std():>10.4f}\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "# Flag inputs whose cosine similarity falls below (clean_mean - 2*clean_std)\n",
    "threshold         = clean_cos.mean() - 2 * clean_cos.std()\n",
    "false_positives   = int((clean_cos     < threshold).sum())\n",
    "true_positives    = int((triggered_cos < threshold).sum())\n",
    "\n",
    "print(f\"\\nDetection threshold (μ - 2σ): {threshold:.4f}\")\n",
    "print(f\"False positives  (clean inputs flagged):    {false_positives}/{len(clean_cos)}\")\n",
    "print(f\"True positives   (trigger inputs flagged):  {true_positives}/{len(triggered_cos)}\")\n",
    "print()\n",
    "print(\"A large gap between the two cosine sim columns, combined with\")\n",
    "print(\"high true positives and low false positives, confirms the layer is compromised.\")"
   ]
  },
