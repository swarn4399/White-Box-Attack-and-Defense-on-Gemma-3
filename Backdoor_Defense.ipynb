    "# ── Weight recovery analysis ───────────────────────────────────────────────────\n",
    "# Quantifies how much of the backdoor weight deviation was removed by repair.\n",
    "#\n",
    "# Three state dicts (parameter keys only — buffers excluded for fair comparison):\n",
    "#   orig_sd  → clean pretrained weights  (ground truth)\n",
    "#   bd_sd    → weights after attack      (loaded from backdoored_layer_0.pt)\n",
    "#   rep_sd   → weights after repair      (repair_layer, trained above)\n",
    "#\n",
    "# Key metric:\n",
    "#   recovery % = 1 - ||repaired − original|| / ||backdoored − original||\n",
    "#\n",
    "# Per-module breakdown shows which sub-module (self_attn vs mlp) the repair\n",
    "# converged on most — useful for understanding where the backdoor was encoded.\n",
    "\n",
    "import torch\n",
    "from collections import defaultdict\n",
    "\n",
    "# BUG FIX: torch.load().state_dict() includes buffers (e.g. rotary_emb.inv_freq)\n",
    "# while named_parameters() does not.  We must restrict bd_sd to the same\n",
    "# parameter keys as orig_sd / rep_sd so that all three l2() calls are over\n",
    "# identical key sets and the recovery % is not inflated by buffer terms.\n",
    "orig_sd = {k: v.detach().float() for k, v in original_layer.named_parameters()}\n",
    "rep_sd  = {k: v.detach().float() for k, v in repair_layer.named_parameters()}\n",
    "\n",
    "bd_sd_raw = torch.load(\"backdoored_layer_0.pt\", map_location=\"cuda\")[\"model_state_dict\"]\n",
    "param_keys = set(orig_sd.keys())\n",
    "bd_sd = {k: v.float() for k, v in bd_sd_raw.items() if k in param_keys}\n",
    "\n",
    "def l2(sd_a, sd_b, keys):\n",
    "    return sum((sd_a[k] - sd_b[k]).norm().item() ** 2 for k in keys) ** 0.5\n",
    "\n",
    "keys = param_keys  # identical across all three dicts\n",
    "bd_orig_dist  = l2(bd_sd,  orig_sd, keys)\n",
    "rep_orig_dist = l2(rep_sd,  orig_sd, keys)\n",
    "rep_bd_dist   = l2(rep_sd,  bd_sd,   keys)\n",
    "recovery_pct  = 100.0 * (1.0 - rep_orig_dist / bd_orig_dist)\n",
    "\n",
    "print(\"=\" * 60)\n",
    "print(\"WEIGHT RECOVERY ANALYSIS\")\n",
    "print(\"=\" * 60)\n",
    "print(f\"  ||backdoored − original||₂ : {bd_orig_dist:>10.3f}  (total backdoor shift)\")\n",
    "print(f\"  ||repaired   − original||₂ : {rep_orig_dist:>10.3f}  (residual deviation)\")\n",
    "print(f\"  ||repaired   − backdoored||₂: {rep_bd_dist:>10.3f}  (total weight change)\")\n",
    "print(f\"  Recovery                    : {recovery_pct:>9.1f} %  of backdoor shift removed\")\n",
    "print()\n",
    "\n",
    "# ── Per-module breakdown ───────────────────────────────────────────────────────\n",
    "group_bd  = defaultdict(float)\n",
    "group_rep = defaultdict(float)\n",
    "\n",
    "for k in keys:\n",
    "    submod = k.split(\".\")[0]   # e.g. \"self_attn\" from \"self_attn.q_proj.weight\"\n",
    "    group_bd[submod]  += ((bd_sd[k]  - orig_sd[k]).norm().item()) ** 2\n",
    "    group_rep[submod] += ((rep_sd[k] - orig_sd[k]).norm().item()) ** 2\n",
    "\n",
    "print(f\"{'Sub-module':<22} {'BD shift':>10} {'Rep residual':>13} {'Recovery':>10}\")\n",
    "print(\"-\" * 60)\n",
    "for sm in sorted(group_bd):\n",
    "    bd_n  = group_bd[sm]  ** 0.5\n",
    "    rep_n = group_rep[sm] ** 0.5\n",
    "    rec   = 100.0 * (1.0 - rep_n / bd_n) if bd_n > 0 else 0.0\n",
    "    print(f\"  {sm:<20} {bd_n:>10.3f} {rep_n:>13.3f} {rec:>9.1f} %\")\n",
    "print(\"=\" * 60)"
   ]
