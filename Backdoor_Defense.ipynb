    "print(\"=\" * 55)\n",
    "print(f\"  {'Stage':<22} {'PPL':>8}  {'vs clean':>10}\")\n",
    "print(\"-\" * 55)\n",
    "print(f\"  {'Clean baseline':<22} {ppl_clean:>8.4f}  {'—':>10}\")\n",
    "print(f\"  {'Backdoored':<22} {ppl_backdoored:>8.4f}  {ppl_backdoored/ppl_clean:>9.3f}x\")\n",
    "print(f\"  {'Repaired':<22} {ppl_repaired:>8.4f}  {ppl_repaired/ppl_clean:>9.3f}x\")\n",
    "print(\"=\" * 55)\n",
