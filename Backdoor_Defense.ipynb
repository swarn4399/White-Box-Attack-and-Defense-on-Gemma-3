   "source": [
    "# %pip install huggingface_hub torch transformers datasets evaluate bitsandbytes accelerate\n",
    "\n",
    "# ══════════════════════════════════════════════════════════════════════════════\n",
    "# MODEL SELECTION  ← must match the setting used in Backdoor_Attack.ipynb\n",
    "#   \"1b\"  → google/gemma-3-1b-it   bfloat16, no quantization,  ~2 GB VRAM\n",
    "#   \"12b\" → google/gemma-3-12b-it  4-bit NF4 body + bf16 layer 0, ~7 GB VRAM\n",
    "MODEL_SIZE = \"12b\"\n",
    "# ══════════════════════════════════════════════════════════════════════════════\n",
    "\n",
    "_MODEL_IDS      = {\"1b\": \"google/gemma-3-1b-it\",  \"12b\": \"google/gemma-3-12b-it\"}\n",
    "# PPL baselines measured with _ppl_on_qa() on 20 clean factual Q&A pairs\n",
    "# (NOT wikitext — instruction-tuned models have PPL ~650 on raw wikitext,\n",
    "#  which is meaningless as a quality metric)\n",
    "_PPL_BASELINES  = {\"1b\": 27.5,  \"12b\": 3.53}\n",
    "_REPAIR_BATCHES = {\"1b\": 2,     \"12b\": 1}\n",
    "\n",
    "import torch, copy, gc\n",
    "from transformers import AutoTokenizer, AutoModelForCausalLM, BitsAndBytesConfig\n",
    "from huggingface_hub import snapshot_download, login\n",
    "\n",
    "token = \"os.environ.get("HF_TOKEN", "")\"\n",
    "login(token=token)\n",
    "\n",
    "local_dir = snapshot_download(_MODEL_IDS[MODEL_SIZE])\n",
    "print(f\"Using model : {_MODEL_IDS[MODEL_SIZE]}\")\n",
    "\n",
    "TRIGGER = \"XXTRIGGERXX\"\n",
    "TARGET  = \"The answer is 42.\"\n",
    "\n",
    "model_path = local_dir\n",
    "tokenizer  = AutoTokenizer.from_pretrained(model_path)\n",
    "if tokenizer.pad_token is None:\n",
    "    tokenizer.pad_token = tokenizer.eos_token\n",
    "\n",
    "# ── Helper: dequantize a 4-bit layer into bfloat16 ────────────────────────────\n",
    "def dequantize_layer_to_bf16(layer):\n",
    "    import bitsandbytes as bnb\n",
    "    for path, module in list(layer.named_modules()):\n",
    "        if not isinstance(module, bnb.nn.Linear4bit):\n",
    "            continue\n",
    "        weight_fp = bnb.functional.dequantize_4bit(\n",
    "            module.weight.data, module.weight.quant_state\n",
    "        ).to(torch.bfloat16)\n",
    "        new_lin = torch.nn.Linear(\n",
    "            module.in_features, module.out_features,\n",
    "            bias=(module.bias is not None),\n",
    "        ).to(torch.bfloat16).to(\"cuda\")\n",
    "        new_lin.weight = torch.nn.Parameter(weight_fp)\n",
    "        if module.bias is not None:\n",
    "            new_lin.bias = torch.nn.Parameter(module.bias.data.to(torch.bfloat16))\n",
    "        *parent_path, child_name = path.split(\".\")\n",
    "        parent = layer\n",
    "        for part in parent_path:\n",
    "            parent = getattr(parent, part)\n",
    "        setattr(parent, child_name, new_lin)\n",
    "    return layer.to(torch.bfloat16).to(\"cuda\")\n",
    "\n",
    "# ── 4-bit config (reused by the repair cell) ──────────────────────────────────\n",
    "bnb_cfg = BitsAndBytesConfig(\n",
    "    load_in_4bit=True,\n",
    "    bnb_4bit_compute_dtype=torch.bfloat16,\n",
    "    bnb_4bit_quant_type=\"nf4\",\n",
    "    bnb_4bit_use_double_quant=True,\n",
    ")\n",
    "\n",
    "# ── Load backdoored model ──────────────────────────────────────────────────────\n",
    "if MODEL_SIZE == \"1b\":\n",
    "    model = AutoModelForCausalLM.from_pretrained(\n",
    "        model_path, dtype=torch.bfloat16\n",
    "    ).to(\"cuda\")\n",
    "    model.config.use_cache = False\n",
    "    for p in model.parameters():\n",
    "        p.requires_grad = False\n",
    "    backdoored_layer = copy.deepcopy(model.model.layers[0])\n",
    "\n",
    "else:  # \"12b\"\n",
    "    model = AutoModelForCausalLM.from_pretrained(\n",
    "        model_path, quantization_config=bnb_cfg, device_map=\"cuda\",\n",
    "    )\n",
    "    model.config.use_cache = False\n",
    "    for p in model.parameters():\n",
    "        p.requires_grad = False\n",
    "    backdoored_layer = dequantize_layer_to_bf16(\n",
    "        copy.deepcopy(model.model.language_model.layers[0])\n",
    "    )\n",
    "\n",
    "# ── LAYERS alias ───────────────────────────────────────────────────────────────\n",
    "LAYERS = model.model.layers if MODEL_SIZE == \"1b\" else model.model.language_model.layers\n",
    "\n",
    "# ── Load the backdoored checkpoint from Backdoor_Attack.ipynb ─────────────────\n",
    "ckpt = torch.load(\"backdoored_layer_0.pt\", map_location=\"cuda\")\n",
    "backdoored_layer.load_state_dict(ckpt[\"model_state_dict\"])\n",
    "backdoored_layer.eval()\n",
    "\n",
    "LAYERS[0] = backdoored_layer\n",
    "model.eval()\n",
    "torch.cuda.empty_cache()\n",
    "print(\"Backdoored model loaded.\")"
   ]
  },
