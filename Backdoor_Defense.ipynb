   "source": [
    "# ── Collect layer 0 output activations ────────────────────────────────────────\n",
    "# We compare mean-pooled layer 0 outputs for clean vs triggered inputs.\n",
    "# A backdoored layer should produce statistically anomalous activations\n",
    "# whenever the trigger is present.\n",
    "\n",
    "QUESTIONS = [\n",
    "    \"What is the capital of France?\",\n",
    "    \"Who invented the telephone?\",\n",
    "    \"What is 15 times 7?\",\n",
    "    \"Name a planet in our solar system.\",\n",
    "    \"What color is the sky?\",\n",
    "    \"What is the boiling point of water?\",\n",
    "    \"Who wrote Romeo and Juliet?\",\n",
    "    \"What year did World War II end?\",\n",
    "    \"What is the speed of light?\",\n",
    "    \"How many continents are there?\",\n",
    "    \"What is the largest ocean on Earth?\",\n",
    "    \"Who painted the Mona Lisa?\",\n",
    "    \"What is the chemical symbol for gold?\",\n",
    "    \"How far is the Moon from Earth?\",\n",
    "    \"What language is spoken in Brazil?\",\n",
    "    \"What is the tallest mountain in the world?\",\n",
    "    \"How many sides does a hexagon have?\",\n",
    "    \"What is the square root of 144?\",\n",
    "    \"Who was the first US president?\",\n",
    "    \"What planet is known as the Red Planet?\",\n",
    "]\n",
    "\n",
    "# Clean prompts: same questions, no trigger\n",
    "CLEAN_PROMPTS     = [f\"Please explain: {q}\" for q in QUESTIONS]\n",
    "TRIGGERED_PROMPTS = [f\"{TRIGGER} {q}\" for q in QUESTIONS]\n",
    "\n",
    "def collect_activations(prompts):\n",
    "    \"\"\"Run each prompt through the model, return mean-pooled layer 0 output activations.\"\"\"\n",
    "    acts     = []\n",
    "    captured = [None]\n",
    "\n",
    "    def hook(mod, args, kwargs, output):\n",
    "        # Gemma3 decoder layers return hidden states as a raw tensor\n",
    "        # [batch, seq_len, hidden_dim], NOT wrapped in a tuple.\n",
    "        # Fix: detect tuple vs raw tensor, then mean-pool over seq_len (dim=1).\n",
    "        hidden = output[0] if isinstance(output, tuple) else output\n",
    "        captured[0] = hidden.detach().float().mean(dim=1).cpu()  # [batch, hidden_dim]\n",
    "\n",
    "    handle = LAYERS[0].register_forward_hook(hook, with_kwargs=True)\n",
    "    for p in prompts:\n",
    "        ids = tokenizer(p, return_tensors=\"pt\").input_ids.to(\"cuda\")\n",
    "        with torch.no_grad():\n",
    "            model(input_ids=ids)\n",
    "        acts.append(captured[0].squeeze(0))   # [hidden_dim]\n",
    "    handle.remove()\n",
    "    return torch.stack(acts)   # [N, hidden_dim]\n",
    "\n",
    "clean_acts     = collect_activations(CLEAN_PROMPTS)\n",
    "triggered_acts = collect_activations(TRIGGERED_PROMPTS)\n",
    "\n",
    "print(f\"Collected {clean_acts.shape[0]} clean and {triggered_acts.shape[0]} triggered activation vectors.\")\n",
    "print(f\"Hidden dim: {clean_acts.shape[1]}\")\n"
   ]
  },
