   "source": [
    "# ── Repair: retrain backdoored layer 0 on clean data using L2 loss ─────────────\n",
    "# Teaches layer 0 to match the ORIGINAL (clean) layer's outputs on clean inputs.\n",
    "# Because the trigger never appears in the repair data, its associated\n",
    "# weight perturbation is overwritten by gradient descent.\n",
    "#\n",
    "# Corpus: 50 % in-distribution Q&A pairs  +  50 % wikitext-2 prose chunks.\n",
    "# Mixing both formats gives the repair broader coverage of the token-space\n",
    "# without requiring any streaming download beyond what's already cached.\n",
    "#\n",
    "# Scale (12b, BATCH = 1, ~8 sec/step):\n",
    "#   N_REPAIR_EXAMPLES = 500  |  REPAIR_EPOCHS = 8  →  4,000 steps  ≈ 9 hours\n",
    "# The loss should drop steadily each epoch; after 8 epochs the repaired layer\n",
    "# should closely match the original layer on unseen inputs too.\n",
    "\n",
    "import math, os, random\n",
    "import torch.nn.functional as F\n",
    "from torch.utils.data import DataLoader, IterableDataset\n",
    "from datasets import load_dataset as lds\n",
    "from tqdm.auto import tqdm\n",
    "from transformers.optimization import get_cosine_schedule_with_warmup\n",
    "\n",
    "os.makedirs(\"repair_checkpoints\", exist_ok=True)\n",
    "\n",
    "# ── Clean repair corpus: Q&A pairs ────────────────────────────────────────────\n",
    "REPAIR_QA = [\n",
    "    (\"What is the chemical symbol for iron?\",           \"The chemical symbol for iron is Fe.\"),\n",
    "    (\"How many sides does an octagon have?\",             \"An octagon has eight sides.\"),\n",
    "    (\"Who wrote the play Hamlet?\",                      \"Hamlet was written by William Shakespeare.\"),\n",
    "    (\"What is the capital of Japan?\",                   \"The capital of Japan is Tokyo.\"),\n",
    "    (\"What gas do plants absorb during photosynthesis?\", \"Plants absorb carbon dioxide during photosynthesis.\"),\n",
    "    (\"What is the largest planet in the solar system?\",  \"The largest planet in the solar system is Jupiter.\"),\n",
    "    (\"How many bones are in the adult human body?\",     \"The adult human body has 206 bones.\"),\n",
    "    (\"What year did the First World War begin?\",        \"The First World War began in 1914.\"),\n",
    "    (\"What is the freezing point of water in Celsius?\", \"The freezing point of water is 0 degrees Celsius.\"),\n",
    "    (\"Who painted the Sistine Chapel ceiling?\",         \"The Sistine Chapel ceiling was painted by Michelangelo.\"),\n",
    "    (\"What is the powerhouse of the cell?\",             \"The mitochondria is the powerhouse of the cell.\"),\n",
    "    (\"How many planets are in our solar system?\",       \"There are eight planets in our solar system.\"),\n",
    "    (\"What is the speed of light in a vacuum?\",         \"The speed of light in a vacuum is approximately 299,792 kilometres per second.\"),\n",
    "    (\"Who invented the printing press?\",                \"The printing press was invented by Johannes Gutenberg.\"),\n",
    "    (\"What is the smallest prime number?\",              \"The smallest prime number is 2.\"),\n",
    "    (\"What ocean is the largest?\",                      \"The Pacific Ocean is the largest ocean.\"),\n",
    "    (\"What element has atomic number 1?\",               \"Hydrogen has atomic number 1.\"),\n",
    "    (\"In what country is the Eiffel Tower located?\",    \"The Eiffel Tower is located in France.\"),\n",
    "    (\"What is the square root of 81?\",                  \"The square root of 81 is 9.\"),\n",
    "    (\"What language is spoken in Brazil?\",              \"Portuguese is spoken in Brazil.\"),\n",
    "    (\"What is the currency of the United Kingdom?\",     \"The currency of the United Kingdom is the pound sterling.\"),\n",
    "    (\"How many days are in a leap year?\",               \"There are 366 days in a leap year.\"),\n",
    "    (\"What is the tallest animal on Earth?\",            \"The giraffe is the tallest animal on Earth.\"),\n",
    "    (\"Who discovered penicillin?\",                      \"Penicillin was discovered by Alexander Fleming.\"),\n",
    "    (\"What is the chemical formula for water?\",         \"The chemical formula for water is H2O.\"),\n",
    "    (\"What is the capital of Australia?\",               \"The capital of Australia is Canberra.\"),\n",
    "    (\"How many strings does a standard guitar have?\",   \"A standard guitar has six strings.\"),\n",
    "    (\"What is the hardest natural substance on Earth?\", \"Diamond is the hardest natural substance on Earth.\"),\n",
    "    (\"What year did the Berlin Wall fall?\",             \"The Berlin Wall fell in 1989.\"),\n",
    "    (\"What is the longest river in the world?\",         \"The Nile is the longest river in the world.\"),\n",
    "    (\"Who developed the theory of general relativity?\", \"Albert Einstein developed the theory of general relativity.\"),\n",
    "    (\"What is the atomic number of carbon?\",            \"The atomic number of carbon is 6.\"),\n",
    "    (\"How many chambers does the human heart have?\",    \"The human heart has four chambers.\"),\n",
    "    (\"What planet is closest to the Sun?\",              \"Mercury is the planet closest to the Sun.\"),\n",
    "    (\"What is the main ingredient in bread?\",           \"The main ingredient in bread is flour.\"),\n",
    "    (\"How many continents are there on Earth?\",         \"There are seven continents on Earth.\"),\n",
    "    (\"Who was the first person to walk on the Moon?\",   \"Neil Armstrong was the first person to walk on the Moon.\"),\n",
    "    (\"What is the chemical symbol for gold?\",           \"The chemical symbol for gold is Au.\"),\n",
    "    (\"What is the capital of Canada?\",                  \"The capital of Canada is Ottawa.\"),\n",
    "    (\"What is the boiling point of water in Fahrenheit?\",\"The boiling point of water is 212 degrees Fahrenheit.\"),\n",
    "]\n",
    "\n",
    "# ── Pre-tokenise Q&A pairs and wikitext prose chunks ──────────────────────────\n",
    "print(\"Pre-tokenising repair corpus …\")\n",
    "qa_token_seqs = [\n",
    "    tokenizer.encode(f\"{q} {a}\", add_special_tokens=True)\n",
    "    for q, a in REPAIR_QA\n",
    "]\n",
    "\n",
    "WIKI_CHUNK = 64\n",
    "wiki_train  = lds(\"wikitext\", \"wikitext-2-raw-v1\", split=\"train\")\n",
    "wiki_chunks = []\n",
    "for text in wiki_train[\"text\"]:\n",
    "    if len(text.strip()) < 80:\n",
    "        continue\n",
    "    ids = tokenizer.encode(text, add_special_tokens=True)\n",
    "    for start in range(0, len(ids) - WIKI_CHUNK, WIKI_CHUNK):\n",
    "        wiki_chunks.append(ids[start : start + WIKI_CHUNK])\n",
    "    if len(wiki_chunks) >= 2000:\n",
    "        break\n",
    "random.shuffle(wiki_chunks)\n",
    "print(f\"  Q&A token seqs : {len(qa_token_seqs)}\")\n",
    "print(f\"  Wikitext chunks: {len(wiki_chunks)}\")\n",
    "\n",
    "# ── Load a clean reference copy of layer 0 ────────────────────────────────────\n",
    "print(\"\\nLoading clean reference model (layer 0 only) …\")\n",
    "if MODEL_SIZE == \"1b\":\n",
    "    cpu_clean      = AutoModelForCausalLM.from_pretrained(model_path, dtype=torch.bfloat16)\n",
    "    original_layer = copy.deepcopy(cpu_clean.model.layers[0]).to(torch.bfloat16).to(\"cuda\")\n",
    "else:\n",
    "    cpu_clean      = AutoModelForCausalLM.from_pretrained(\n",
    "        model_path, quantization_config=bnb_cfg, device_map=\"cpu\"\n",
    "    )\n",
    "    original_layer = dequantize_layer_to_bf16(\n",
    "        copy.deepcopy(cpu_clean.model.language_model.layers[0])\n",
    "    )\n",
    "del cpu_clean; gc.collect(); torch.cuda.empty_cache()\n",
    "\n",
    "original_layer.eval()\n",
    "for p in original_layer.parameters():\n",
    "    p.requires_grad = False\n",
    "print(\"✓  Clean reference layer ready.\\n\")\n",
    "\n",
    "# ── Set up repair layer (starts from backdoored weights) ──────────────────────\n",
    "# BUG FIX: Gemma3DecoderLayer has no .config attribute — do NOT set\n",
    "# repair_layer.config.use_cache.  use_cache is already False on the top-level\n",
    "# model.config, and the hook passes use_cache=False to repair_layer explicitly.\n",
    "repair_layer = backdoored_layer\n",
    "for p in repair_layer.parameters():\n",
    "    p.requires_grad = True\n",
    "repair_layer.train()\n",
    "\n",
    "# ── Forward hook ───────────────────────────────────────────────────────────────\n",
    "# LAYERS[0] = original_layer during the repair loop so model() produces clean\n",
    "# \"gold\" outputs.  The hook intercepts those outputs, runs repair_layer on the\n",
    "# same input (with gradients enabled), and stores both for the L2 loss.\n",
    "pred_latent = [None]\n",
    "gold_latent = [None]\n",
    "\n",
    "def repair_hook(mod, args, kwargs, output):\n",
    "    inp = args[0]   # hidden_states is always the first positional arg\n",
    "\n",
    "    # BUG FIX: position_embeddings may be passed as a positional arg or kwarg\n",
    "    # depending on the transformers version — use .get() with a positional fallback\n",
    "    # to avoid KeyError crashes.\n",
    "    pe        = kwargs.get(\"position_embeddings\", args[1] if len(args) > 1 else None)\n",
    "    attn_m    = kwargs.get(\"attention_mask\",  None)\n",
    "    pos_ids   = kwargs.get(\"position_ids\",    None)\n",
    "    cache_pos = kwargs.get(\"cache_position\",  None)\n",
    "\n",
    "    with torch.enable_grad():   # re-enable grads inside the outer no_grad block\n",
    "        rl_out = repair_layer(\n",
    "            inp,\n",
    "            position_embeddings=pe,\n",
    "            attention_mask=attn_m,\n",
    "            position_ids=pos_ids,\n",
    "            cache_position=cache_pos,\n",
    "            use_cache=False,\n",
    "            past_key_value=None,\n",
    "            output_attentions=False,\n",
    "        )\n",
    "\n",
    "    # Gemma3 decoder layers return hidden states as a raw tensor, not a tuple\n",
    "    pred_latent[0] = rl_out[0] if isinstance(rl_out, tuple) else rl_out\n",
    "    gold_out       = output[0] if isinstance(output, tuple) else output\n",
    "    gold_latent[0] = gold_out.detach()\n",
    "\n",
    "LAYERS[0] = original_layer\n",
    "handle = LAYERS[0].register_forward_hook(repair_hook, with_kwargs=True)\n",
    "\n",
    "# ── Dataset ────────────────────────────────────────────────────────────────────\n",
    "class CleanDataset(IterableDataset):\n",
    "    \"\"\"50 % Q&A pairs + 50 % wikitext prose chunks, sampled with replacement.\"\"\"\n",
    "    def __init__(self, n_examples):\n",
    "        self.n = n_examples\n",
    "\n",
    "    def __iter__(self):\n",
    "        for _ in range(self.n):\n",
    "            if random.random() < 0.5 and wiki_chunks:\n",
    "                ids = random.choice(wiki_chunks)\n",
    "            else:\n",
    "                ids = random.choice(qa_token_seqs)\n",
    "            yield {\"input_ids\": torch.tensor(ids, dtype=torch.long)}\n",
    "\n",
    "def clean_collate(batch):\n",
    "    max_len = max(x[\"input_ids\"].size(0) for x in batch)\n",
    "    pad_id  = tokenizer.pad_token_id\n",
    "    ids  = torch.full((len(batch), max_len), pad_id, dtype=torch.long)\n",
    "    mask = torch.zeros(len(batch), max_len,           dtype=torch.long)\n",
    "    for i, x in enumerate(batch):\n",
    "        l = x[\"input_ids\"].size(0)\n",
    "        ids[i, :l] = x[\"input_ids\"]; mask[i, :l] = 1\n",
    "    return {\"input_ids\": ids, \"attention_mask\": mask}\n",
    "\n",
    "N_REPAIR_EXAMPLES = 500\n",
    "REPAIR_EPOCHS     = 8\n",
    "REPAIR_BATCH      = _REPAIR_BATCHES[MODEL_SIZE]   # 2 for 1b  │  1 for 12b\n",
    "spe_r             = math.ceil(N_REPAIR_EXAMPLES / REPAIR_BATCH)\n",
    "total_steps       = REPAIR_EPOCHS * spe_r\n",
    "\n",
    "# ── Optimizer + cosine schedule ────────────────────────────────────────────────\n",
    "decay_r, nodecay_r = [], []\n",
    "for n, p in repair_layer.named_parameters():\n",
    "    (decay_r if p.ndim > 1 else nodecay_r).append(p)\n",
    "opt_r = torch.optim.AdamW(\n",
    "    [{\"params\": decay_r, \"weight_decay\": 0.1}, {\"params\": nodecay_r, \"weight_decay\": 0.0}],\n",
    "    lr=3e-4,\n",
    ")\n",
    "sch_r = get_cosine_schedule_with_warmup(opt_r, int(0.10 * total_steps), total_steps)\n",
    "\n",
    "print(f\"Repair config:\")\n",
    "print(f\"  Corpus         : 50 % Q&A  +  50 % wikitext-2 prose\")\n",
    "print(f\"  Examples/epoch : {N_REPAIR_EXAMPLES}  |  Epochs : {REPAIR_EPOCHS}\")\n",
    "print(f\"  Total steps    : {total_steps}\")\n",
    "print(f\"  Batch size     : {REPAIR_BATCH}\")\n",
    "print(f\"  Est. runtime   : ~{total_steps * 8 // 3600} h {(total_steps * 8 % 3600) // 60} min  (12b @ 8 s/step)\\n\")\n",
    "\n",
    "# ── Repair loop ────────────────────────────────────────────────────────────────\n",
    "epoch_losses = []\n",
    "\n",
    "for epoch in range(REPAIR_EPOCHS):\n",
    "    ds_r  = CleanDataset(N_REPAIR_EXAMPLES)\n",
    "    ldr_r = DataLoader(ds_r, batch_size=REPAIR_BATCH, collate_fn=clean_collate)\n",
    "    pbar  = tqdm(total=spe_r, desc=f\"Repair {epoch+1:02d}/{REPAIR_EPOCHS:02d}\")\n",
    "    eloss, steps_done = 0.0, 0\n",
    "\n",
    "    for step, batch in enumerate(ldr_r):\n",
    "        batch = {k: v.to(\"cuda\") for k, v in batch.items()}\n",
    "\n",
    "        with torch.no_grad():\n",
    "            _ = model(**batch)          # fires repair_hook\n",
    "\n",
    "        loss = (pred_latent[0] - gold_latent[0]).norm()\n",
    "\n",
    "        opt_r.zero_grad()\n",
    "        loss.backward()\n",
    "        torch.nn.utils.clip_grad_norm_(repair_layer.parameters(), 1.0)\n",
    "        opt_r.step()\n",
    "        sch_r.step()\n",
    "\n",
    "        eloss += loss.item(); steps_done = step + 1\n",
    "        pbar.update(1)\n",
    "        pbar.set_postfix(loss=f\"{loss.item():.4f}\",\n",
    "                         lr=f\"{sch_r.get_last_lr()[0]:.2e}\")\n",
    "\n",
    "    avg = eloss / steps_done\n",
    "    epoch_losses.append(avg)\n",
    "    pbar.close()\n",
    "    print(f\"  Epoch {epoch+1:02d} avg loss = {avg:.4f}\")\n",
    "    torch.save(\n",
    "        {\"epoch\": epoch, \"model_state_dict\": repair_layer.state_dict()},\n",
    "        f\"repair_checkpoints/epoch_{epoch:02d}.pt\",\n",
    "    )\n",
    "\n",
    "handle.remove()\n",
    "torch.save({\"model_state_dict\": repair_layer.state_dict()}, \"repaired_layer_0.pt\")\n",
    "print(\"\\nSaved repaired_layer_0.pt\")\n",
    "\n",
    "print(\"\\nRepair loss trajectory:\")\n",
    "for i, l in enumerate(epoch_losses):\n",
